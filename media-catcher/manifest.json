{
  "manifest_version": 2,
  "name": "Media Catcher",
  "version": "1.4.2",
  "description": "Detects and downloads video/audio from a tab \u2014 HLS (.m3u8) with AES-128, MPEG-DASH (.mpd), live-stream recording, byte-range, subtitles, and one-click yt-dlp/ffmpeg commands.",
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "downloads",
    "downloads.open",
    "webRequest",
    "webRequestBlocking",
    "<all_urls>",
    "notifications",
    "contextMenus",
    "nativeMessaging"
  ],
  "background": {
    "scripts": [
      "lib/hls.js",
      "lib/dash.js",
      "lib/commands.js",
      "lib/filename.js",
      "lib/mux.js",
      "background.js"
    ],
    "persistent": true
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "browser_action": {
    "default_title": "Media Catcher",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "{27383706-fb43-40dc-9e94-d2578818bd6a}",
      "strict_min_version": "142.0",
      "update_url": "https://github.com/g9xdev/mCatcher/releases/latest/download/updates.json",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  }
}